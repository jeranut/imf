<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_microfinance_data_reset_wizard_form" model="ir.ui.view">
        <field name="name">microfinance.data.reset.wizard.form</field>
        <field name="model">microfinance.data.reset.wizard</field>
        <field name="arch" type="xml">
            <form string="RAZ Microfinance - Remise à zéro par agence">
                <div class="alert alert-danger" role="alert">
                    <strong>⚠️ Action irréversible.</strong>
                    Ce module supprime définitivement des données microfinance
                    (crédits, échéanciers, remboursements, garanties, scoring, visites
                    de recouvrement, comptes et transactions d'épargne, écritures
                    comptables liées) pour les agences sélectionnées.
                    Les clients (res.partner), les produits de crédit/épargne, les
                    profils de scoring, le plan comptable et la configuration des
                    sociétés ne sont jamais touchés.
                    <strong>Faites un backup complet de la base avant toute
                    exécution réelle.</strong>
                    Un verrou empêche toute exécution simultanée : si un message
                    "opération déjà en cours" apparaît, patientez que l'opération en
                    cours se termine avant de réessayer.
                </div>

                <group invisible="state != 'draft'">
                    <field name="company_ids" widget="many2many_tags"
                           options="{'no_create': True}"/>
                </group>

                <group string="Périmètre à supprimer"
                       invisible="state != 'draft'">
                    <group>
                        <field name="do_loans"/>
                        <field name="do_loan_installments"/>
                        <field name="do_loan_payments"/>
                        <field name="do_loan_guarantees"/>
                        <field name="do_scoring_lines"/>
                    </group>
                    <group>
                        <field name="do_reschedule_history"/>
                        <field name="do_collection_visits"/>
                        <field name="do_savings_accounts"/>
                        <field name="do_savings_transactions"/>
                        <field name="do_accounting_entries"/>
                    </group>
                </group>

                <group invisible="state != 'draft'">
                    <field name="i_confirm"/>
                    <field name="confirm_text" invisible="not i_confirm"/>
                </group>

                <group invisible="state == 'draft'">
                    <field name="is_dry_run" readonly="1"
                           string="Mode simulation (dry-run) ?"/>
                    <field name="current_label" readonly="1" nolabel="0"/>
                    <field name="batch_progress" readonly="1" nolabel="0"
                           invisible="not batch_progress"/>
                    <label for="progress" string="Progression"/>
                    <div>
                        <field name="progress" widget="progressbar"
                               options="{'editable': false}"/>
                        <span>
                            <field name="step_index" readonly="1"/> /
                            <field name="total_steps" readonly="1"/> agences
                        </span>
                    </div>
                </group>

                <field name="state" invisible="1"/>

                <group string="Trace en direct" invisible="not live_trace">
                    <field name="live_trace" nolabel="1" widget="text" readonly="1"
                           style="font-family: monospace; white-space: pre-wrap;
                           max-height: 200px; overflow-y: auto; display: block;"/>
                </group>

                <group string="Journal des résultats"
                       invisible="not log">
                    <field name="log" nolabel="1" widget="text" readonly="1"
                           style="font-family: monospace; white-space: pre-wrap;"/>
                </group>

                <footer>
                    <button name="action_preview_counts" type="object"
                            string="Aperçu (lecture seule)" class="btn-secondary"
                            invisible="state != 'draft'"/>
                    <button name="action_start_dry_run" type="object"
                            string="Démarrer la simulation (dry-run)" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start_execute" type="object"
                            string="Démarrer l'exécution réelle" class="btn-danger"
                            invisible="state != 'draft'"
                            confirm="Cette action va supprimer définitivement les données microfinance sélectionnées. Confirmer ?"/>

                    <button name="action_process_next_step" type="object"
                            string="▶ Étape suivante" class="btn-primary"
                            invisible="state != 'running'"/>
                    <field name="id" invisible="state != 'running'" nolabel="1"
                           widget="microfinance_data_reset_auto_runner"/>

                    <button name="action_reset_wizard" type="object"
                            string="Nouvelle opération" class="btn-secondary"
                            invisible="state != 'done'"/>

                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_microfinance_data_reset_wizard" model="ir.actions.act_window">
        <field name="name">RAZ Microfinance</field>
        <field name="res_model">microfinance.data.reset.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_microfinance_data_reset_wizard_root"
              name="RAZ Microfinance"
              parent="base.menu_administration"
              sequence="101"
              groups="base.group_system"/>

    <menuitem id="menu_microfinance_data_reset_wizard"
              name="Assistant de RAZ microfinance"
              parent="menu_microfinance_data_reset_wizard_root"
              action="action_microfinance_data_reset_wizard"
              groups="base.group_system"/>

</odoo>
