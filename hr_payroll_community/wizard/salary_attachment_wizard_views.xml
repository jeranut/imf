<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Formulaire de l'assistant Retenue sur Salaire -->
    <record id="salary_attachment_wizard_view_form" model="ir.ui.view">
        <field name="name">hr.salary.attachment.wizard.view.form</field>
        <field name="model">hr.salary.attachment.wizard</field>
        <field name="arch" type="xml">
            <form string="Appliquer une Retenue sur Salaire">
                <header>
                    <button string="Appliquer" name="action_apply"
                            type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <group col="4">
                        <field name="employee_ids" widget="many2many_tags"
                               colspan="4"/>
                        <field name="attachment_type"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="amount"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Action -->
    <record id="salary_attachment_wizard_action" model="ir.actions.act_window">
        <field name="name">Appliquer une Retenue sur Salaire</field>
        <field name="res_model">hr.salary.attachment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <menuitem id="menu_salary_attachment_wizard"
              name="Appliquer une Retenue en Masse"
              parent="menu_hr_payroll_community_configuration"
              action="salary_attachment_wizard_action"
              sequence="21"/>
</odoo>
