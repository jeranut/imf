<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Formulaire de l'assistant Avantage en Nature -->
    <record id="salary_benefit_wizard_view_form" model="ir.ui.view">
        <field name="name">hr.contract.salary.benefit.wizard.view.form</field>
        <field name="model">hr.contract.salary.benefit.wizard</field>
        <field name="arch" type="xml">
            <form string="Configurer un Avantage en Nature">
                <header>
                    <button string="Appliquer" name="action_apply"
                            type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <group col="4">
                        <field name="contract_id"/>
                        <field name="benefit_type"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="taxable_value"/>
                        <field name="non_taxable_value"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Action -->
    <record id="salary_benefit_wizard_action" model="ir.actions.act_window">
        <field name="name">Configurer un Avantage en Nature</field>
        <field name="res_model">hr.contract.salary.benefit.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="salary_benefit_wizard_view_form"/>
        <field name="target">new</field>
    </record>
</odoo>
