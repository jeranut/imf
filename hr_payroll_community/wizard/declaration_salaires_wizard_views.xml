<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Formulaire de l'assistant Déclaration des Salaires -->
    <record id="declaration_salaires_wizard_view_form" model="ir.ui.view">
        <field name="name">hr.declaration.salaires.wizard.view.form</field>
        <field name="model">hr.declaration.salaires.wizard</field>
        <field name="arch" type="xml">
            <form string="Déclaration des Salaires">
                <header>
                    <button string="Générer le fichier XLSX"
                            name="action_generate_xlsx" type="object"
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <group col="4">
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="company_id"
                               groups="base.group_multi_company"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Action de l'assistant Déclaration des Salaires -->
    <record id="declaration_salaires_wizard_action" model="ir.actions.act_window">
        <field name="name">Déclaration des Salaires</field>
        <field name="res_model">hr.declaration.salaires.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="declaration_salaires_wizard_view_form"/>
        <field name="target">new</field>
    </record>
    <!-- Menu Reporting -->
    <menuitem id="menu_hr_payroll_community_reporting" name="Reporting"
              parent="menu_hr_payroll_community_root"
              sequence="90"
              groups="hr_payroll_community.group_hr_payroll_community_user"/>
    <menuitem id="menu_declaration_salaires_wizard"
              name="Déclaration des Salaires"
              parent="menu_hr_payroll_community_reporting"
              action="declaration_salaires_wizard_action"
              sequence="10"/>
</odoo>
