<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue liste des retenues sur salaire -->
    <record id="hr_salary_attachment_view_tree" model="ir.ui.view">
        <field name="name">hr.salary.attachment.view.tree</field>
        <field name="model">hr.salary.attachment</field>
        <field name="arch" type="xml">
            <tree string="Retenues sur Salaire">
                <field name="employee_ids" widget="many2many_tags"/>
                <field name="attachment_type"/>
                <field name="amount"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>
    <!-- Formulaire des retenues sur salaire -->
    <record id="hr_salary_attachment_view_form" model="ir.ui.view">
        <field name="name">hr.salary.attachment.view.form</field>
        <field name="model">hr.salary.attachment</field>
        <field name="arch" type="xml">
            <form string="Retenue sur Salaire">
                <sheet>
                    <group col="4">
                        <field name="employee_ids" widget="many2many_tags"
                               colspan="4"/>
                        <field name="attachment_type"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="amount"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="active"/>
                        <field name="company_id"
                               groups="base.group_multi_company"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Action -->
    <record id="hr_salary_attachment_action" model="ir.actions.act_window">
        <field name="name">Retenues sur Salaire</field>
        <field name="res_model">hr.salary.attachment</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_hr_salary_attachment"
              name="Retenues sur Salaire"
              parent="menu_hr_payroll_community_configuration"
              action="hr_salary_attachment_action"
              sequence="20"/>
</odoo>
