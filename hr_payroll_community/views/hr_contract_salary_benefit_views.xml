<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Avantages en nature, intégrés au formulaire du contrat -->
    <record id="hr_contract_view_form_benefit" model="ir.ui.view">
        <field name="name">hr.contract.view.form.inherit.benefit</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='allowances']" position="after">
                <group string="Avantages en Nature" name="benefits">
                    <field name="benefit_ids" nolabel="1" colspan="2">
                        <tree editable="bottom">
                            <field name="benefit_type"/>
                            <field name="taxable_value"/>
                            <field name="non_taxable_value"/>
                        </tree>
                    </field>
                    <button name="%(salary_benefit_wizard_action)d"
                            string="Configurer un Avantage" type="action"
                            class="btn-link"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
