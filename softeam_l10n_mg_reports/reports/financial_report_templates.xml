<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_mg_financial_pdf" model="ir.actions.report">
        <field name="name">Rapport financier</field>
        <field name="model">softeam.l10n.mg.financial.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">softeam_l10n_mg_reports.report_mg_financial_pdf</field>
        <field name="report_file">softeam_l10n_mg_reports.report_mg_financial_pdf</field>
        <field name="binding_model_id" ref="model_softeam_l10n_mg_financial_report_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_mg_financial_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div t-raw="doc.html_content"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
