<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="balance_sheet" model="account.report">
        <field name="name">Bilan - Madagascar (PCG 2005)</field>
        <field name="country_id" ref="base.mg"/>
        <field name="availability_condition">country</field>
        <field name="filter_unfold_all" eval="True"/>
        <field name="filter_period_comparison" eval="True"/>
        <field name="filter_growth_comparison" eval="False"/>
        <field name="filter_journals" eval="True"/>
        <field name="filter_analytic" eval="True"/>
        <field name="filter_show_draft" eval="True"/>
        <field name="column_ids">
            <record id="bs_balance" model="account.report.column">
                <field name="name">Net</field>
                <field name="expression_label">balance</field>
            </record>
        </field>
        <field name="line_ids">
            <!-- ============================================ -->
            <!-- ACTIF                                        -->
            <!-- ============================================ -->
            <record id="bs_actif" model="account.report.line">
                <field name="name">ACTIF</field>
                <field name="hierarchy_level">0</field>
                <field name="children_ids">

                    <!-- ACTIFS NON COURANTS -->
                    <record id="bs_anc" model="account.report.line">
                        <field name="name">ACTIFS NON COURANTS</field>
                        <field name="code">mg_anc</field>
                        <field name="hierarchy_level">1</field>
                        <field name="children_ids">
                            <record id="bs_anc_incorp" model="account.report.line">
                                <field name="name">Immobilisations incorporelles (20)</field>
                                <field name="code">mg_anc_incorp</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_incorp_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">20</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_anc_corp" model="account.report.line">
                                <field name="name">Immobilisations corporelles (21)</field>
                                <field name="code">mg_anc_corp</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_corp_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">21</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_anc_concession" model="account.report.line">
                                <field name="name">Immobilisations en concession (22)</field>
                                <field name="code">mg_anc_concession</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_concession_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">22</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_anc_cours" model="account.report.line">
                                <field name="name">Immobilisations en cours (23)</field>
                                <field name="code">mg_anc_cours</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_cours_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">23</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_anc_partic" model="account.report.line">
                                <field name="name">Participations et créances rattachées (26)</field>
                                <field name="code">mg_anc_partic</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_partic_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">26</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_anc_immo_fin" model="account.report.line">
                                <field name="name">Autres immobilisations financières (27)</field>
                                <field name="code">mg_anc_immo_fin</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_immo_fin_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">27</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_anc_amort" model="account.report.line">
                                <field name="name">Amortissements et pertes de valeur (28-29)</field>
                                <field name="code">mg_anc_amort</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_amort_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">28 + 29</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_anc_imp_diff" model="account.report.line">
                                <field name="name">Impôts différés actif (133)</field>
                                <field name="code">mg_anc_imp_diff</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_imp_diff_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">133</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_anc_total" model="account.report.line">
                                <field name="name">TOTAL ACTIFS NON COURANTS</field>
                                <field name="code">mg_anc_total</field>
                                <field name="hierarchy_level">2</field>
                                <field name="expression_ids">
                                    <record id="bs_anc_total_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">aggregation</field>
                                        <field name="formula">mg_anc_incorp.balance + mg_anc_corp.balance + mg_anc_concession.balance + mg_anc_cours.balance + mg_anc_partic.balance + mg_anc_immo_fin.balance + mg_anc_amort.balance + mg_anc_imp_diff.balance</field>
                                    </record>
                                </field>
                            </record>
                        </field>
                    </record>

                    <!-- ACTIFS COURANTS -->
                    <record id="bs_ac" model="account.report.line">
                        <field name="name">ACTIFS COURANTS</field>
                        <field name="code">mg_ac</field>
                        <field name="hierarchy_level">1</field>
                        <field name="children_ids">
                            <record id="bs_ac_stocks" model="account.report.line">
                                <field name="name">Stocks et en-cours (3)</field>
                                <field name="code">mg_ac_stocks</field>
                                <field name="expression_ids">
                                    <record id="bs_ac_stocks_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">3</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_ac_clients" model="account.report.line">
                                <field name="name">Clients et comptes rattachés (41)</field>
                                <field name="code">mg_ac_clients</field>
                                <field name="expression_ids">
                                    <record id="bs_ac_clients_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">41</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_ac_etat" model="account.report.line">
                                <field name="name">État, créances (44 débiteur)</field>
                                <field name="code">mg_ac_etat</field>
                                <field name="expression_ids">
                                    <record id="bs_ac_etat_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">44D</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_ac_autres" model="account.report.line">
                                <field name="name">Autres débiteurs (40-débit, 42-débit, 46-débit)</field>
                                <field name="code">mg_ac_autres</field>
                                <field name="expression_ids">
                                    <record id="bs_ac_autres_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">40D + 42D + 46D</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_ac_avance" model="account.report.line">
                                <field name="name">Charges constatées d'avance (486)</field>
                                <field name="code">mg_ac_avance</field>
                                <field name="expression_ids">
                                    <record id="bs_ac_avance_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">486</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_ac_vmp" model="account.report.line">
                                <field name="name">Valeurs mobilières de placement (50)</field>
                                <field name="code">mg_ac_vmp</field>
                                <field name="expression_ids">
                                    <record id="bs_ac_vmp_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">50</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_ac_treso" model="account.report.line">
                                <field name="name">Banques et caisse (51 + 53 + 54 + 58)</field>
                                <field name="code">mg_ac_treso</field>
                                <field name="expression_ids">
                                    <record id="bs_ac_treso_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">51 + 53 + 54 + 58</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_ac_total" model="account.report.line">
                                <field name="name">TOTAL ACTIFS COURANTS</field>
                                <field name="code">mg_ac_total</field>
                                <field name="hierarchy_level">2</field>
                                <field name="expression_ids">
                                    <record id="bs_ac_total_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">aggregation</field>
                                        <field name="formula">mg_ac_stocks.balance + mg_ac_clients.balance + mg_ac_etat.balance + mg_ac_autres.balance + mg_ac_avance.balance + mg_ac_vmp.balance + mg_ac_treso.balance</field>
                                    </record>
                                </field>
                            </record>
                        </field>
                    </record>

                    <!-- TOTAL ACTIF -->
                    <record id="bs_actif_total" model="account.report.line">
                        <field name="name">TOTAL ACTIF</field>
                        <field name="code">mg_actif_total</field>
                        <field name="hierarchy_level">0</field>
                        <field name="expression_ids">
                            <record id="bs_actif_total_bal" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">mg_anc_total.balance + mg_ac_total.balance</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>

            <!-- ============================================ -->
            <!-- CAPITAUX PROPRES & PASSIFS                   -->
            <!-- ============================================ -->
            <record id="bs_passif" model="account.report.line">
                <field name="name">CAPITAUX PROPRES &amp; PASSIFS</field>
                <field name="hierarchy_level">0</field>
                <field name="children_ids">

                    <!-- CAPITAUX PROPRES -->
                    <record id="bs_cp" model="account.report.line">
                        <field name="name">CAPITAUX PROPRES</field>
                        <field name="code">mg_cp</field>
                        <field name="hierarchy_level">1</field>
                        <field name="children_ids">
                            <record id="bs_cp_capital" model="account.report.line">
                                <field name="name">Capital (10)</field>
                                <field name="code">mg_cp_capital</field>
                                <field name="expression_ids">
                                    <record id="bs_cp_capital_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">-10</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_cp_report" model="account.report.line">
                                <field name="name">Report à nouveau (11)</field>
                                <field name="code">mg_cp_report</field>
                                <field name="expression_ids">
                                    <record id="bs_cp_report_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">-11</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_cp_resultat" model="account.report.line">
                                <field name="name">Résultat de l'exercice (12)</field>
                                <field name="code">mg_cp_resultat</field>
                                <field name="expression_ids">
                                    <record id="bs_cp_resultat_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">-12</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_cp_total" model="account.report.line">
                                <field name="name">TOTAL CAPITAUX PROPRES</field>
                                <field name="code">mg_cp_total</field>
                                <field name="hierarchy_level">2</field>
                                <field name="expression_ids">
                                    <record id="bs_cp_total_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">aggregation</field>
                                        <field name="formula">mg_cp_capital.balance + mg_cp_report.balance + mg_cp_resultat.balance</field>
                                    </record>
                                </field>
                            </record>
                        </field>
                    </record>

                    <!-- PASSIFS NON COURANTS -->
                    <record id="bs_pnc" model="account.report.line">
                        <field name="name">PASSIFS NON COURANTS</field>
                        <field name="code">mg_pnc</field>
                        <field name="hierarchy_level">1</field>
                        <field name="children_ids">
                            <record id="bs_pnc_subv" model="account.report.line">
                                <field name="name">Subventions / produits différés (13)</field>
                                <field name="code">mg_pnc_subv</field>
                                <field name="expression_ids">
                                    <record id="bs_pnc_subv_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">-13</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pnc_provisions" model="account.report.line">
                                <field name="name">Provisions pour charges (15)</field>
                                <field name="code">mg_pnc_provisions</field>
                                <field name="expression_ids">
                                    <record id="bs_pnc_provisions_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">-15</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pnc_emprunts" model="account.report.line">
                                <field name="name">Emprunts et dettes assimilées (16-17-18)</field>
                                <field name="code">mg_pnc_emprunts</field>
                                <field name="expression_ids">
                                    <record id="bs_pnc_emprunts_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">-16 - 17 - 18</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pnc_total" model="account.report.line">
                                <field name="name">TOTAL PASSIFS NON COURANTS</field>
                                <field name="code">mg_pnc_total</field>
                                <field name="hierarchy_level">2</field>
                                <field name="expression_ids">
                                    <record id="bs_pnc_total_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">aggregation</field>
                                        <field name="formula">mg_pnc_subv.balance + mg_pnc_provisions.balance + mg_pnc_emprunts.balance</field>
                                    </record>
                                </field>
                            </record>
                        </field>
                    </record>

                    <!-- PASSIFS COURANTS -->
                    <record id="bs_pc" model="account.report.line">
                        <field name="name">PASSIFS COURANTS</field>
                        <field name="code">mg_pc</field>
                        <field name="hierarchy_level">1</field>
                        <field name="children_ids">
                            <record id="bs_pc_fourn" model="account.report.line">
                                <field name="name">Fournisseurs et comptes rattachés (40)</field>
                                <field name="code">mg_pc_fourn</field>
                                <field name="expression_ids">
                                    <record id="bs_pc_fourn_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">40C</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pc_personnel" model="account.report.line">
                                <field name="name">Personnel (42)</field>
                                <field name="code">mg_pc_personnel</field>
                                <field name="expression_ids">
                                    <record id="bs_pc_personnel_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">42C</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pc_organismes" model="account.report.line">
                                <field name="name">Organismes sociaux (43)</field>
                                <field name="code">mg_pc_organismes</field>
                                <field name="expression_ids">
                                    <record id="bs_pc_organismes_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">43C</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pc_etat" model="account.report.line">
                                <field name="name">État, dettes (44 créditeur, TVA, IS)</field>
                                <field name="code">mg_pc_etat</field>
                                <field name="expression_ids">
                                    <record id="bs_pc_etat_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">44C</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pc_autres" model="account.report.line">
                                <field name="name">Autres créditeurs (45-46 créditeur)</field>
                                <field name="code">mg_pc_autres</field>
                                <field name="expression_ids">
                                    <record id="bs_pc_autres_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">45C + 46C</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pc_provisions" model="account.report.line">
                                <field name="name">Provisions et produits constatés d'avance (481+487)</field>
                                <field name="code">mg_pc_provisions</field>
                                <field name="expression_ids">
                                    <record id="bs_pc_provisions_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">481 + 487</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pc_concours" model="account.report.line">
                                <field name="name">Concours bancaires (519)</field>
                                <field name="code">mg_pc_concours</field>
                                <field name="expression_ids">
                                    <record id="bs_pc_concours_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">account_codes</field>
                                        <field name="formula">519</field>
                                    </record>
                                </field>
                            </record>
                            <record id="bs_pc_total" model="account.report.line">
                                <field name="name">TOTAL PASSIFS COURANTS</field>
                                <field name="code">mg_pc_total</field>
                                <field name="hierarchy_level">2</field>
                                <field name="expression_ids">
                                    <record id="bs_pc_total_bal" model="account.report.expression">
                                        <field name="label">balance</field>
                                        <field name="engine">aggregation</field>
                                        <field name="formula">mg_pc_fourn.balance + mg_pc_personnel.balance + mg_pc_organismes.balance + mg_pc_etat.balance + mg_pc_autres.balance + mg_pc_provisions.balance + mg_pc_concours.balance</field>
                                    </record>
                                </field>
                            </record>
                        </field>
                    </record>

                    <!-- TOTAL CP & PASSIFS -->
                    <record id="bs_passif_total" model="account.report.line">
                        <field name="name">TOTAL CAPITAUX PROPRES &amp; PASSIFS</field>
                        <field name="code">mg_passif_total</field>
                        <field name="hierarchy_level">0</field>
                        <field name="expression_ids">
                            <record id="bs_passif_total_bal" model="account.report.expression">
                                <field name="label">balance</field>
                                <field name="engine">aggregation</field>
                                <field name="formula">mg_cp_total.balance + mg_pnc_total.balance + mg_pc_total.balance</field>
                            </record>
                        </field>
                    </record>
                </field>
            </record>
        </field>
    </record>
</odoo>
