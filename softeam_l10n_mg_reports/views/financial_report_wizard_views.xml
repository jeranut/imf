<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mg_financial_report_wizard_form" model="ir.ui.view">
        <field name="name">softeam.l10n.mg.financial.report.wizard.form</field>
        <field name="model">softeam.l10n.mg.financial.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Rapport financier">
                <header>
                    <button name="action_generate_html" type="object" string="Afficher" class="btn-primary"/>
                    <button name="action_print_pdf" type="object" string="Imprimer PDF"/>
                    <button name="action_export_xlsx" type="object" string="Exporter Excel"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="report_type" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="target_move"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="journal_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <separator string="Résultat"/>
                    <field name="html_content" nolabel="1" readonly="1" widget="html"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mg_report_balance_sheet" model="ir.actions.act_window">
        <field name="name">Bilan</field>
        <field name="res_model">softeam.l10n.mg.financial.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_mg_financial_report_wizard_form"/>
        <field name="target">current</field>
        <field name="context">{'default_report_type': 'balance_sheet'}</field>
    </record>
    <record id="action_mg_report_income_statement" model="ir.actions.act_window">
        <field name="name">Compte de résultat</field>
        <field name="res_model">softeam.l10n.mg.financial.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_mg_financial_report_wizard_form"/>
        <field name="target">current</field>
        <field name="context">{'default_report_type': 'income_statement'}</field>
    </record>
    <record id="action_mg_report_general_balance" model="ir.actions.act_window">
