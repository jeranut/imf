    <record id="action_mg_report_general_ledger" model="ir.actions.act_window">
        <field name="name">Grand livre</field>
        <field name="res_model">softeam.l10n.mg.financial.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_mg_financial_report_wizard_form"/>
        <field name="target">current</field>
        <field name="context">{'default_report_type': 'general_ledger'}</field>
    </record>
    <record id="action_mg_report_journals" model="ir.actions.act_window">
        <field name="name">Journaux</field>
        <field name="res_model">softeam.l10n.mg.financial.report.wizard</field>
