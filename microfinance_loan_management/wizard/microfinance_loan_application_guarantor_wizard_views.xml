<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_loan_application_guarantor_wizard_form" model="ir.ui.view">
        <field name="name">microfinance.loan.application.guarantor.wizard.form</field>
        <field name="model">microfinance.loan.application.guarantor.wizard</field>
        <field name="arch" type="xml">
            <form string="Modifier les garants">
                <field name="application_id" invisible="1"/>
                <field name="line_ids">
                    <tree editable="bottom">
                        <field name="partner_id"/>
                        <field name="name"/>
                        <field name="id_card_number"/>
                        <field name="address"/>
                        <field name="phone"/>
                        <field name="profession"/>
                        <field name="relationship_to_borrower"/>
                    </tree>
                </field>
                <footer>
                    <button string="Valider" type="object" name="action_validate" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
