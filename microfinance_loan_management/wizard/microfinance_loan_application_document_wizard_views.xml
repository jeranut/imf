<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_loan_application_document_wizard_form" model="ir.ui.view">
        <field name="name">microfinance.loan.application.document.wizard.form</field>
        <field name="model">microfinance.loan.application.document.wizard</field>
        <field name="arch" type="xml">
            <form string="Modifier les documents administratifs fournis">
                <field name="application_id" invisible="1"/>
                <field name="line_ids">
                    <tree editable="bottom">
                        <field name="name"/>
                        <field name="is_provided" widget="boolean_toggle"/>
                        <field name="comment"/>
                    </tree>
                </field>
                <footer>
                    <button string="Valider" type="object" name="action_validate" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
