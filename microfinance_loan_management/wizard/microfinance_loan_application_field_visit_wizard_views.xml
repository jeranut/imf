<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_loan_application_field_visit_wizard_form" model="ir.ui.view">
        <field name="name">microfinance.loan.application.field.visit.wizard.form</field>
        <field name="model">microfinance.loan.application.field.visit.wizard</field>
        <field name="arch" type="xml">
            <form string="Modifier les visites terrain">
                <field name="application_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>
                <group string="Visite à domicile (VAD)">
                    <field name="line_ids" string="VAD" nolabel="1"
                        context="{'default_visit_type': 'home', 'default_is_counter_visit': False}"
                        domain="[('visit_type', '=', 'home'), ('is_counter_visit', '=', False)]">
                        <tree editable="bottom">
                            <field name="agent_id"/>
                            <field name="visit_date"/>
                            <field name="constats"/>
                            <field name="neighborhood_reputation"/>
                            <field name="visit_type" column_invisible="1"/>
                            <field name="is_counter_visit" column_invisible="1"/>
                        </tree>
                    </field>
                    <field name="line_ids" string="Contre-VAD" nolabel="1"
                        context="{'default_visit_type': 'home', 'default_is_counter_visit': True}"
                        domain="[('visit_type', '=', 'home'), ('is_counter_visit', '=', True)]">
                        <tree editable="bottom">
                            <field name="agent_id"/>
                            <field name="visit_date"/>
                            <field name="counter_visit_of_id"/>
                            <field name="constats"/>
                            <field name="neighborhood_reputation"/>
                            <field name="wizard_id" column_invisible="1"/>
                            <field name="visit_type" column_invisible="1"/>
                            <field name="is_counter_visit" column_invisible="1"/>
                        </tree>
                    </field>
                </group>
                <group string="Visite au lieu de vente (VAV)">
                    <field name="line_ids" string="VAV" nolabel="1"
                        context="{'default_visit_type': 'sales_point', 'default_is_counter_visit': False}"
                        domain="[('visit_type', '=', 'sales_point'), ('is_counter_visit', '=', False)]">
                        <tree editable="bottom">
                            <field name="agent_id"/>
                            <field name="visit_date"/>
                            <field name="project_exists"/>
                            <field name="potential_clients_level"/>
                            <field name="stock_value"/>
                            <field name="competition_level"/>
                            <field name="product_presentation"/>
                            <field name="commercial_attitude"/>
                            <field name="visit_type" column_invisible="1"/>
                            <field name="is_counter_visit" column_invisible="1"/>
                        </tree>
                    </field>
                    <field name="line_ids" string="Contre-VAV" nolabel="1"
                        context="{'default_visit_type': 'sales_point', 'default_is_counter_visit': True}"
                        domain="[('visit_type', '=', 'sales_point'), ('is_counter_visit', '=', True)]">
                        <tree editable="bottom">
                            <field name="agent_id"/>
                            <field name="visit_date"/>
                            <field name="counter_visit_of_id"/>
                            <field name="project_exists"/>
                            <field name="potential_clients_level"/>
                            <field name="stock_value"/>
                            <field name="competition_level"/>
                            <field name="product_presentation"/>
                            <field name="commercial_attitude"/>
                            <field name="wizard_id" column_invisible="1"/>
                            <field name="visit_type" column_invisible="1"/>
                            <field name="is_counter_visit" column_invisible="1"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button string="Valider" type="object" name="action_validate" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
