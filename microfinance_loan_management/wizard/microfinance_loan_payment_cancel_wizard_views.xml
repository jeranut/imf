<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_payment_cancel_wizard_form" model="ir.ui.view">
        <field name="name">microfinance.loan.payment.cancel.wizard.form</field>
        <field name="model">microfinance.loan.payment.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Annulation remboursement">
                <group>
                    <field name="payment_id" readonly="1"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirmer l'annulation" type="object" class="btn-primary"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
