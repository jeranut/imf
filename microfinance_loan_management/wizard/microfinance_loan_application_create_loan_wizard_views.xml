<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_loan_application_create_loan_wizard_form" model="ir.ui.view">
        <field name="name">microfinance.loan.application.create.loan.wizard.form</field>
        <field name="model">microfinance.loan.application.create.loan.wizard</field>
        <field name="arch" type="xml">
            <form string="Créer le crédit">
                <field name="application_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>
                <group>
                    <field name="partner_id" readonly="1"/>
                    <!-- Pas de groups="base.group_multi_company" : le domaine de product_id
                         ci-dessous référence company_id, qui doit donc rester présent dans
                         la vue quel que soit le groupe. -->
                    <field name="company_id" readonly="1"/>
                    <field name="product_id"/>
                    <field name="loan_amount"/>
                    <field name="term"/>
                </group>
                <footer>
                    <button string="Créer le crédit" type="object" name="action_validate" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
