<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_loan_application_partner_wizard_form" model="ir.ui.view">
        <field name="name">microfinance.loan.application.partner.wizard.form</field>
        <field name="model">microfinance.loan.application.partner.wizard</field>
        <field name="arch" type="xml">
            <form string="Modifier l'identification du partenaire">
                <field name="application_id" invisible="1"/>
                <group>
                    <group string="Identité">
                        <field name="partner_surname"/>
                        <field name="partner_id_card_number"/>
                        <field name="partner_id_card_issue_date"/>
                        <field name="partner_id_card_issue_place"/>
                        <field name="partner_birth_date"/>
                        <field name="partner_birth_place"/>
                        <field name="partner_marital_status"/>
                    </group>
                    <group string="Adresse et contact">
                        <field name="partner_current_address"/>
                        <field name="partner_fokontany"/>
                        <field name="partner_address_since"/>
                        <field name="partner_housing_status"/>
                        <field name="partner_phone"/>
                        <field name="partner_reference_contact_name"/>
                        <field name="partner_reference_contact_phone"/>
                    </group>
                </group>
                <group string="Conjoint" invisible="partner_marital_status != 'married'">
                    <group>
                        <field name="spouse_name"/>
                        <field name="spouse_id_card_number"/>
                        <field name="spouse_address"/>
                        <field name="spouse_fokontany"/>
                    </group>
                    <group>
                        <field name="spouse_profession"/>
                        <field name="spouse_employer"/>
                        <field name="spouse_phone"/>
                        <field name="union_duration"/>
                    </group>
                </group>
                <field name="dependent_line_ids" string="Enfants et personnes à charge">
                    <tree editable="bottom">
                        <field name="name"/>
                        <field name="relationship"/>
                        <field name="birth_date"/>
                        <field name="occupation"/>
                    </tree>
                </field>
                <field name="surveyor_comment" placeholder="Commentaire de l'enquêteur..."/>
                <footer>
                    <button string="Valider" type="object" name="action_validate" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
