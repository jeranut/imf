<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_partner_form" model="ir.ui.view">
        <field name="name">res.partner.form.microfinance</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Smart buttons : masquer Facturé (module account), ajouter Crédit -->
            <xpath expr="//button[@name='action_view_partner_invoices']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button class="oe_stat_button" type="object" name="action_view_microfinance_loans" icon="fa-money"
                    invisible="not context.get('microfinance_context')">
                    <field name="microfinance_loan_count" widget="statinfo" string="Crédit"/>
                </button>
            </xpath>

            <!-- Radio 2 boutons (Particulier/Société) en remplacement du radio natif. microfinance_partner_type
                 n'est jamais un choix utilisateur (toujours dérivé par le code, cf. res_partner.py) : chargé
                 en invisible="1" uniquement pour que les conditions invisible= des blocs LPF et des onglets
                 puissent le lire côté client. -->
            <xpath expr="//field[@name='company_type']" position="replace">
                <field name="microfinance_partner_type" invisible="1"/>
                <field name="microfinance_client_type" widget="radio" options="{'horizontal': true}"
                    string="Type de client"
                    invisible="not context.get('microfinance_context') or microfinance_partner_type != 'client'"/>
                <field name="company_type" widget="radio" options="{'horizontal': true}"
                    invisible="context.get('microfinance_context')"/>
            </xpath>

            <!-- Ajustements du groupe "Contact" natif -->
            <xpath expr="//div[hasclass('o_address_format')]//field[@name='street']" position="attributes">
                <attribute name="placeholder">Adresse...</attribute>
            </xpath>
            <xpath expr="//div[hasclass('o_address_format')]//field[@name='street2']" position="attributes">
                <attribute name="placeholder">Adresse 2...</attribute>
            </xpath>
            <xpath expr="//div[hasclass('o_address_format')]//field[@name='state_id']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>
            <xpath expr="//div[hasclass('o_address_format')]//field[@name='country_id']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>
            <xpath expr="//div[hasclass('o_address_format')]//field[@name='city']" position="attributes">
                <attribute name="placeholder">Ville</attribute>
            </xpath>
            <xpath expr="//div[hasclass('o_address_format')]//field[@name='zip']" position="attributes">
                <attribute name="placeholder">Code postal</attribute>
            </xpath>
            <!-- Commune (BCM) juste avant Ville, puisqu'elle la pilote automatiquement (cf.
                 onchange côté modèle : city/zip/district_id/region_id dérivés de la commune
                 choisie, pas de double saisie). Visible pour tout type de client (Particulier
                 et Société), uniquement en contexte microfinance (EAT/immobilier non
                 concernés, ce champ reste vide hors de ce contexte). -->
            <xpath expr="//div[hasclass('o_address_format')]//field[@name='city']" position="before">
                <field name="microfinance_commune_id" placeholder="Rechercher une commune..."
                       invisible="not context.get('microfinance_context')"/>
            </xpath>
            <!-- Fokontany/Région/District juste après le bloc adresse : Fokontany reste une
                 sélection manuelle (affine la commune, prioritaire sur Code postal si plus
                 précis) ; Région/District sont dérivés de la commune et donc readonly, jamais
                 saisis à la main. Restent vides si la commune n'est pas encore rattachée à un
                 district (721 communes sur 1645, cf. docs/unmatched_ambiguous_report.csv). -->
            <xpath expr="//div[hasclass('o_address_format')]" position="after">
                <field name="microfinance_fokontany_id" placeholder="Rechercher un fokontany..."
                       domain="[('commune_id', '=', microfinance_commune_id)]"
                       invisible="not context.get('microfinance_context')"/>
                <field name="microfinance_region_id" readonly="1" placeholder="Région (auto)"
                       invisible="not context.get('microfinance_context')"/>
                <field name="microfinance_district_id" readonly="1" placeholder="District (auto)"
                       invisible="not context.get('microfinance_context')"/>
            </xpath>
            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>
            <!-- base_vat déplace vat dans un conteneur avec un label explicite ; masquer
                 aussi cet habillage sinon le libellé "N° TVA" reste visible sans le champ. -->
            <xpath expr="//label[@for='vat']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>
            <xpath expr="//div[@name='vat_vies_container']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>
            <!-- Un particulier n'a normalement ni TVA ni site web professionnel dans le référentiel
                 LPF ; une société ou entreprise en a potentiellement. vat reste masqué dans tous les
                 cas (redondant avec microfinance_nif/microfinance_stat/microfinance_rcs plus bas). -->
            <xpath expr="//field[@name='website']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context') and microfinance_client_type == 'individual'</attribute>
            </xpath>

            <!-- Blocs de champs par type, hors notebook, juste après le groupe Contact -->
            <xpath expr="//notebook" position="before">

                <group invisible="microfinance_client_type != 'individual' or not context.get('microfinance_context') or microfinance_partner_type != 'client'">
                    <group string="Identification">
                        <field name="microfinance_registration_number" placeholder="Numéro d'inscription interne"/>
                        <field name="microfinance_id_type"/>
                        <field name="microfinance_id_number_display" string="N° CIN" placeholder="123 456 789 012"
                            widget="microfinance_grouped_digits" invisible="microfinance_id_type != 'cin'"/>
                        <field name="microfinance_id_number" string="N° pièce d'identité" placeholder="Numéro de la pièce d'identité" invisible="microfinance_id_type == 'cin'"/>
                        <field name="microfinance_id_issue_date" invisible="microfinance_id_type != 'cin'"/>
                        <field name="microfinance_id_issue_place" placeholder="Ex: Antananarivo" invisible="microfinance_id_type != 'cin'"/>
                        <field name="microfinance_birthdate"/>
                        <field name="microfinance_gender"/>
                        <field name="microfinance_marital_status"/>
                        <field name="microfinance_profession" placeholder="Rechercher ou créer une profession..."/>
                        <field name="microfinance_education_level"/>
                    </group>
                    <group string="Famille et compte">
                        <!-- "Créer et modifier" ouvre le formulaire res.partner complet (pas de
                             view_id forcé), avec l'adresse du client courant préremplie via
                             default_* — évalué dynamiquement à chaque ouverture depuis les
                             valeurs actuelles du formulaire, pas des valeurs figées.
                             microfinance_context est propagé pour que ce formulaire affiche
                             aussi nos sections (dont Commune/Fokontany/Région/District, pour
                             que le préremplissage soit visible, pas seulement enregistré). -->
                        <!-- Visible pour toute situation matrimoniale sauf Célibataire (permet de
                             renseigner un ex-conjoint ou conjoint décédé à titre informatif pour
                             Divorcé(e)/Veuf(ve), sans le rendre obligatoire pour eux — seul
                             "Marié(e)" l'exige, cf. _check_spouse_required_if_married). -->
                        <field name="microfinance_spouse_id" placeholder="Rechercher ou créer le conjoint..."
                            invisible="microfinance_marital_status == 'single'"
                            required="microfinance_marital_status == 'married'"
                            context="{
                                'default_street': street, 'default_street2': street2,
                                'default_city': city, 'default_zip': zip,
                                'default_microfinance_commune_id': microfinance_commune_id,
                                'default_microfinance_fokontany_id': microfinance_fokontany_id,
                                'default_microfinance_region_id': microfinance_region_id,
                                'default_microfinance_district_id': microfinance_district_id,
                                'microfinance_context': True,
                            }"/>
                        <field name="microfinance_spouse_phone" placeholder="Ex: 034 12 345 67"
                            invisible="microfinance_marital_status == 'single'"
                            required="microfinance_marital_status == 'married'"/>
                        <field name="microfinance_spouse_profession" placeholder="Rechercher ou créer une profession..."
                            invisible="microfinance_marital_status == 'single'"/>
                        <field name="microfinance_next_of_kin_name" placeholder="Nom de la personne à contacter en cas d'urgence"/>
                        <field name="microfinance_next_of_kin_address" placeholder="Adresse de cette personne"/>
                        <field name="microfinance_co_holder_name" placeholder="Nom du co-titulaire du compte, le cas échéant"/>
                        <!-- Pas de context de préremplissage ici : le garant a typiquement une
                             adresse différente du client, formulaire de création vierge
                             (comportement Many2one standard). -->
                        <field name="microfinance_guarantor_id" placeholder="Rechercher ou créer le garant..."/>
                        <field name="microfinance_required_signatures"/>
                    </group>
                </group>

                <group invisible="microfinance_client_type != 'company' or not context.get('microfinance_context') or microfinance_partner_type != 'client'">
                    <group string="Identité légale">
                        <field name="microfinance_trade_name" placeholder="Nom commercial de l'entreprise"/>
                        <field name="microfinance_acronym" placeholder="Sigle ou acronyme"/>
                        <field name="microfinance_enterprise_type"/>
                        <field name="microfinance_nif" placeholder="123 122 123 123"/>
                        <field name="microfinance_stat" placeholder="12345 11 2020 0 12345"/>
                        <field name="microfinance_rcs" placeholder="2020B00123"/>
                        <field name="microfinance_legal_form" placeholder="Ex: SARL, EURL, Association..."/>
                        <field name="microfinance_creation_date"/>
                    </group>
                    <group string="Activité et finances">
                        <field name="microfinance_business_sector" placeholder="Ex: Commerce, Agriculture, Artisanat..."/>
                        <field name="microfinance_main_activity" placeholder="Description de l'activité principale"/>
                        <field name="microfinance_share_capital"/>
                        <field name="microfinance_estimated_turnover"/>
                        <field name="microfinance_employee_count"/>
                    </group>
                </group>
                <group invisible="microfinance_client_type != 'company' or not context.get('microfinance_context') or microfinance_partner_type != 'client'">
                    <group string="Localisation étendue">
                        <field name="microfinance_region" placeholder="Région"/>
                        <field name="microfinance_district" placeholder="District"/>
                        <field name="microfinance_commune" placeholder="Commune"/>
                        <field name="microfinance_locality" placeholder="Fokontany / localité"/>
                    </group>
                    <group string="Fermeture">
                        <field name="microfinance_closure_date"/>
                        <field name="microfinance_closure_reason" placeholder="Motif de la fermeture du dossier"/>
                    </group>
                </group>

                <group invisible="microfinance_client_type != 'company' or not context.get('microfinance_context') or microfinance_partner_type != 'client'" string="Comité">
                    <field name="microfinance_representative_ids" nolabel="1" colspan="2">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="id_card_number"/>
                            <field name="role"/>
                            <field name="account_authorization"/>
                        </tree>
                    </field>
                </group>

            </xpath>

            <!-- Masquage des 3 onglets natifs en contexte microfinance -->
            <xpath expr="//page[@name='contact_addresses']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>
            <xpath expr="//page[@name='accounting']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context') or (not is_company and parent_id)</attribute>
            </xpath>
            <xpath expr="//page[@name='accounting_disabled']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context') or (is_company or not parent_id)</attribute>
            </xpath>
            <!-- Onglet "Assignation de partenaire" (base_geolocalize, technical name geo_location,
                 pas partner_assign) : non pertinent pour un client microfinance. -->
            <xpath expr="//page[@name='geo_location']" position="attributes">
                <attribute name="invisible">context.get('microfinance_context')</attribute>
            </xpath>

            <!-- Onglets Épargne et Crédit, à côté de Notes internes -->
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="Épargne" name="microfinance_savings" invisible="not context.get('microfinance_context') or microfinance_partner_type != 'client'">
                    <p class="text-muted">Module épargne en cours d'implémentation.</p>
                </page>
                <page string="Crédit" name="microfinance_credits" invisible="not context.get('microfinance_context') or microfinance_partner_type != 'client'">
                    <field name="microfinance_loan_ids" nolabel="1" readonly="1">
                        <tree>
                            <field name="name"/>
                            <field name="loan_amount"/>
                            <field name="state"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_microfinance_client" model="ir.actions.act_window">
        <field name="name">Clients</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('microfinance_partner_type', '=', 'client')]</field>
        <field name="context">{'microfinance_context': True, 'default_microfinance_client_type': 'individual', 'default_microfinance_partner_type': 'client'}</field>
    </record>

    <!-- Madagascar par défaut sur res.partner (instance majoritairement basée à Madagascar) -->
    <record id="default_partner_country_mg" model="ir.default">
        <field name="field_id" search="[('model', '=', 'res.partner'), ('name', '=', 'country_id')]"/>
        <field name="json_value">141</field>
    </record>
</odoo>
