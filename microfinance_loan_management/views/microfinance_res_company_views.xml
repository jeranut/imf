<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_microfinance_loan" model="ir.ui.view">
        <field name="name">res.company.form.inherit.microfinance.loan</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="agency_code" placeholder="ex. IS"/>
                <field name="loan_product_code_locked" invisible="1"/>
                <field name="loan_product_code_prefix" readonly="loan_product_code_locked"/>
                <!-- groups ici uniquement (pas de groups= au niveau champ Python) : réservé à
                     group_microfinance_manager, cohérent avec le menu Configuration déjà réservé
                     à ce groupe, sans bloquer la lecture par l'onchange de pré-remplissage côté
                     microfinance.loan pour un simple agent créant un crédit. -->
                <field name="microfinance_fond_credit_default_id"
                       groups="microfinance_loan_management.group_microfinance_manager"/>
                <field name="microfinance_social_grid_include_savings"
                       groups="microfinance_loan_management.group_microfinance_manager"/>
                <field name="microfinance_social_grid_include_administrative"
                       groups="microfinance_loan_management.group_microfinance_manager"/>
                <field name="microfinance_social_grid_include_impression_in_total"
                       groups="microfinance_loan_management.group_microfinance_manager"/>
                <field name="microfinance_social_grid_include_impression_next_loan"
                       groups="microfinance_loan_management.group_microfinance_manager"/>
                <field name="microfinance_social_grid_impression_next_loan_min_score"
                       invisible="not microfinance_social_grid_include_impression_next_loan"
                       groups="microfinance_loan_management.group_microfinance_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
