<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_provision_rule_tree" model="ir.ui.view">
        <field name="name">microfinance.provision.rule.tree</field>
        <field name="model">microfinance.provision.rule</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="min_days"/>
                <field name="max_days"/>
                <field name="provision_rate"/>
                <field name="name" column_invisible="1"/>
            </tree>
        </field>
    </record>
    <record id="view_microfinance_provision_rule_form" model="ir.ui.view">
        <field name="name">microfinance.provision.rule.form</field>
        <field name="model">microfinance.provision.rule</field>
        <field name="arch" type="xml">
            <form string="Règle de provisionnement">
                <group>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="min_days"/>
                    <field name="max_days"/>
                    <field name="provision_rate"/>
                </group>
            </form>
        </field>
    </record>
    <record id="action_microfinance_provision_rule" model="ir.actions.act_window">
        <field name="name">Règles de provisionnement</field>
        <field name="res_model">microfinance.provision.rule</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
