<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_visit_tree" model="ir.ui.view"><field name="name">microfinance.collection.visit.tree</field><field name="model">microfinance.collection.visit</field><field name="arch" type="xml"><tree><field name="loan_id"/><field name="partner_id"/><field name="agent_id"/><field name="visit_date"/><field name="next_visit_date"/><field name="status" widget="badge"/><field name="promise_to_pay_date"/><field name="promised_amount"/></tree></field></record>
