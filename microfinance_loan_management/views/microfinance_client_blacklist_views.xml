<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_client_blacklist_tree" model="ir.ui.view">
        <field name="name">microfinance.client.blacklist.tree</field>
        <field name="model">microfinance.client.blacklist</field>
        <field name="arch" type="xml">
            <tree decoration-muted="not active">
                <field name="partner_id"/>
                <field name="reason"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>
    <record id="view_microfinance_client_blacklist_form" model="ir.ui.view">
        <field name="name">microfinance.client.blacklist.form</field>
        <field name="model">microfinance.client.blacklist</field>
        <field name="arch" type="xml">
            <form string="Liste noire">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="reason"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_microfinance_client_blacklist_search" model="ir.ui.view">
        <field name="name">microfinance.client.blacklist.search</field>
        <field name="model">microfinance.client.blacklist</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="reason"/>
                <filter name="inactive" string="Inactifs" domain="[('active', '=', False)]"/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_by_partner" string="Client" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_microfinance_client_blacklist" model="ir.actions.act_window">
        <field name="name">Liste noire</field>
        <field name="res_model">microfinance.client.blacklist</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_inactive': 0}</field>
    </record>
</odoo>
