<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Numérotation de microfinance.loan et microfinance.loan.application : plus de séquence
         globale ici, remplacée par une séquence dédiée par société créée à la demande (voir
         res.company._get_or_create_numbering_sequence), format AGENCE/SÉRIE. -->
    <record id="seq_microfinance_payment" model="ir.sequence">
        <field name="name">Remboursement microfinance</field>
        <field name="code">microfinance.loan.payment</field>
        <field name="prefix">PAY/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <!-- Pas de préfixe statique ici : le préfixe est configurable par société
         (res.company.loan_product_code_prefix) et concaténé en Python à la création du
         produit. Séquence volontairement globale (company_id vide), comme les deux ci-dessus :
         un compteur unique pour toutes les sociétés, plus simple à maintenir qu'un compteur par
         société — seul le préfixe affiché varie selon la société. -->
    <record id="seq_microfinance_loan_product" model="ir.sequence">
        <field name="name">Code produit de crédit microfinance</field>
        <field name="code">microfinance.loan.product</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
