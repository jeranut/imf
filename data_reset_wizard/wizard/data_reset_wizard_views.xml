<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_data_reset_wizard_form" model="ir.ui.view">
        <field name="name">data.reset.wizard.form</field>
        <field name="model">data.reset.wizard</field>
        <field name="arch" type="xml">
            <form string="RAZ - Remise à zéro des données transactionnelles">
                <div class="alert alert-danger" role="alert">
                    <strong>⚠️ Action irréversible.</strong>
                    Ce module supprime définitivement des données (paiements, factures,
                    commandes, mouvements de stock) pour les sociétés sélectionnées.
                    Les produits, unités de mesure et la configuration ne sont pas
                    touchés. <strong>Faites un backup complet de la base avant toute
                    exécution réelle.</strong>
                    Un verrou empêche toute exécution simultanée : si un message
                    "opération déjà en cours" apparaît (par exemple en cliquant deux
                    fois, ou depuis un autre onglet/utilisateur), patientez que
                    l'opération en cours se termine avant de réessayer.
                </div>

                <group invisible="state != 'draft'">
                    <field name="company_ids" widget="many2many_tags"
                           options="{'no_create': True}"/>
                </group>

                <group string="Périmètre à supprimer"
                       invisible="state != 'draft'">
                    <group>
                        <field name="do_payments"/>
                        <field name="do_advance_payment"/>
                        <field name="do_intercompany"/>
                        <field name="do_invoices"/>
                        <field name="do_purchase"/>
                    </group>
                    <group>
                        <field name="do_sale"/>
                        <field name="do_stock"/>
                        <field name="do_quants"/>
                        <field name="do_daily_balance"/>
                        <field name="do_daily_balance_mobile"/>
                        <field name="do_hr_expense"/>
                    </group>
                </group>

                <group invisible="state != 'draft'">
                    <field name="i_confirm"/>
                </group>

                <!-- Barre de progression, visible pendant/après le traitement -->
                <group invisible="state == 'draft'">
                    <field name="is_dry_run" readonly="1"
                           string="Mode simulation (dry-run) ?"/>
                    <field name="current_label" readonly="1" nolabel="0"/>
                    <field name="batch_progress" readonly="1" nolabel="0"
                           invisible="not batch_progress"/>
                    <label for="progress" string="Progression"/>
                    <div>
                        <field name="progress" widget="progressbar"
                               options="{'editable': false}"/>
                        <span>
                            <field name="step_index" readonly="1"/> / 
                            <field name="total_steps" readonly="1"/> étapes
                        </span>
                    </div>
                </group>

                <field name="state" invisible="1"/>

                <group string="Trace en direct" invisible="not live_trace">
                    <field name="live_trace" nolabel="1" widget="text" readonly="1"
                           style="font-family: monospace; white-space: pre-wrap;
                           max-height: 200px; overflow-y: auto; display: block;"/>
                </group>

                <group string="Journal des résultats"
                       invisible="not log">
                    <field name="log" nolabel="1" widget="text" readonly="1"
                           style="font-family: monospace; white-space: pre-wrap;"/>
                </group>

                <footer>
                    <!-- État brouillon : configuration -->
                    <button name="action_preview_counts" type="object"
                            string="Aperçu (lecture seule)" class="btn-secondary"
                            invisible="state != 'draft'"/>
                    <button name="action_start_dry_run" type="object"
                            string="Démarrer la simulation (dry-run)" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start_execute" type="object"
                            string="Démarrer l'exécution réelle" class="btn-danger"
                            invisible="state != 'draft'"
                            confirm="Cette action va supprimer définitivement les données sélectionnées. Confirmer ?"/>

                    <!-- État en cours : avancer -->
                    <button name="action_process_next_step" type="object"
                            string="▶ Étape suivante" class="btn-primary"
                            invisible="state != 'running'"/>
                    <!-- "Tout traiter" est géré côté client (widget OWL) par des
                         appels répétés à action_process_next_step, un par un :
                         chaque requête HTTP reste courte quel que soit le volume
                         total, ce qui évite de dépasser limit_time_real. -->
                    <field name="id" invisible="state != 'running'" nolabel="1"
                           widget="data_reset_auto_runner"/>

                    <!-- État terminé -->
                    <button name="action_reset_wizard" type="object"
                            string="Nouvelle opération" class="btn-secondary"
                            invisible="state != 'done'"/>

                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_data_reset_wizard" model="ir.actions.act_window">
        <field name="name">RAZ données transactionnelles</field>
        <field name="res_model">data.reset.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_data_reset_wizard_root"
              name="RAZ Données"
              parent="base.menu_administration"
              sequence="100"
              groups="base.group_system"/>

    <menuitem id="menu_data_reset_wizard"
              name="Assistant de RAZ"
              parent="menu_data_reset_wizard_root"
              action="action_data_reset_wizard"
              groups="base.group_system"/>

</odoo>
