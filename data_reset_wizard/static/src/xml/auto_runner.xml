<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="data_reset_wizard.AutoRunner">
        <div class="o_data_reset_auto_runner d-inline-flex align-items-center gap-2">
            <button type="button" class="btn btn-secondary"
                    t-on-click="onClickStart"
                    t-att-disabled="state.running">
                ⏩ Tout traiter (auto, arrêtable)
            </button>
            <button type="button" class="btn btn-outline-danger"
                    t-if="state.running"
                    t-on-click="onClickStop">
                ⏹ Arrêter après le lot en cours
            </button>
            <span class="text-muted fst-italic" t-if="state.running">
                Exécution automatique en cours…
            </span>
        </div>
    </t>
</templates>
