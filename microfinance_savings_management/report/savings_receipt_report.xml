<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_microfinance_savings_receipt" model="ir.actions.report">
        <field name="name">Reçu de transaction épargne</field>
        <field name="model">microfinance.savings.transaction</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">microfinance_savings_management.report_microfinance_savings_receipt_document</field>
        <field name="report_file">microfinance_savings_management.report_microfinance_savings_receipt_document</field>
        <field name="print_report_name">'Reçu épargne - %s - %s' % (object.account_id.name, object.date)</field>
        <field name="binding_model_id" ref="model_microfinance_savings_transaction"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_microfinance_savings_receipt_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Reçu de transaction épargne</h2>
                        <p>
                            Émis par <span t-field="o.company_id.name"/>
                        </p>
                        <table class="table table-sm" style="margin-top: 20px;">
                            <tr>
                                <td><strong>Compte épargne</strong></td>
                                <td><span t-field="o.account_id.name"/></td>
                            </tr>
                            <tr>
                                <td><strong>Titulaire</strong></td>
                                <td><span t-field="o.partner_id.display_name"/></td>
                            </tr>
                            <tr>
                                <td><strong>Produit d'épargne</strong></td>
                                <td><span t-field="o.account_id.product_id.name"/></td>
                            </tr>
                            <tr>
                                <td><strong>Type de transaction</strong></td>
                                <td><span t-field="o.transaction_type"/></td>
                            </tr>
                            <tr>
                                <td><strong>Montant</strong></td>
                                <td><span t-field="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                            </tr>
                            <tr>
                                <td><strong>Date</strong></td>
                                <td><span t-field="o.date"/></td>
                            </tr>
                            <tr>
                                <td><strong>Moyen de paiement</strong></td>
                                <td><span t-field="o.payment_method"/></td>
                            </tr>
                            <tr>
                                <td><strong>Solde après transaction</strong></td>
                                <td><span t-field="o.account_id.balance" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                            </tr>
                        </table>
                        <div style="margin-top: 60px;" class="row">
                            <div class="col-6">
                                <p>Signature de l'agent</p>
                                <br/><br/>
                                <p>____________________________</p>
                            </div>
                            <div class="col-6">
                                <p>Signature du titulaire</p>
                                <br/><br/>
                                <p>____________________________</p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
