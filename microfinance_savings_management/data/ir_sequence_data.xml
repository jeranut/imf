<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_microfinance_savings_account" model="ir.sequence">
        <field name="name">Compte épargne microfinance</field>
        <field name="code">microfinance.savings.account</field>
        <field name="prefix">EP/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <!-- Préfixe configurable par société (res.company.savings_product_code_prefix), concaténé
         en Python à la création du produit — séquence globale, même logique que ci-dessus. -->
    <record id="seq_microfinance_savings_product" model="ir.sequence">
        <field name="name">Code produit d'épargne microfinance</field>
        <field name="code">microfinance.savings.product</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
