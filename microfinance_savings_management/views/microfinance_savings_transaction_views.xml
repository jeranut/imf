<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_savings_transaction_tree" model="ir.ui.view">
        <field name="name">microfinance.savings.transaction.tree</field>
        <field name="model">microfinance.savings.transaction</field>
        <field name="arch" type="xml">
            <tree decoration-danger="transaction_type in ('withdrawal','fee_debit','auto_debit')" decoration-success="transaction_type in ('deposit','interest_credit')">
                <field name="date"/>
                <field name="account_id"/>
                <field name="partner_id"/>
                <field name="transaction_type"/>
                <field name="amount"/>
                <field name="payment_method"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_microfinance_savings_transaction_form" model="ir.ui.view">
        <field name="name">microfinance.savings.transaction.form</field>
        <field name="model">microfinance.savings.transaction</field>
        <field name="arch" type="xml">
            <form string="Transaction épargne">
                <header>
                    <button name="action_post" string="Comptabiliser" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="%(action_report_microfinance_savings_receipt)d" string="Imprimer le reçu" type="action" invisible="state != 'posted'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="account_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="transaction_type"/>
                            <field name="amount"/>
                            <field name="date"/>
                            <field name="payment_method"/>
                        </group>
                        <group>
                            <field name="bypass_min_balance" invisible="transaction_type not in ('withdrawal','auto_debit')"/>
                            <field name="related_loan_payment_id" readonly="1"/>
                            <field name="move_id" readonly="1"/>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_microfinance_savings_transaction_search" model="ir.ui.view">
        <field name="name">microfinance.savings.transaction.search</field>
        <field name="model">microfinance.savings.transaction</field>
        <field name="arch" type="xml">
            <search>
                <field name="account_id"/>
                <field name="partner_id"/>
                <filter name="posted" string="Comptabilisées" domain="[('state','=','posted')]"/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_type" string="Type" context="{'group_by':'transaction_type'}"/>
                    <filter name="group_account" string="Compte" context="{'group_by':'account_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_microfinance_savings_transaction" model="ir.actions.act_window">
        <field name="name">Transactions épargne</field>
        <field name="res_model">microfinance.savings.transaction</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
