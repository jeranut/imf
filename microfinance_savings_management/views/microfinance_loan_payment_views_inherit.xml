<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_microfinance_payment_tree_inherit_savings" model="ir.ui.view">
        <field name="name">microfinance.loan.payment.tree.inherit.savings</field>
        <field name="model">microfinance.loan.payment</field>
        <field name="inherit_id" ref="microfinance_loan_management.view_microfinance_payment_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="payment_origin"/>
            </field>
        </field>
    </record>
    <record id="view_microfinance_payment_form_inherit_savings" model="ir.ui.view">
        <field name="name">microfinance.loan.payment.form.inherit.savings</field>
        <field name="model">microfinance.loan.payment</field>
        <field name="inherit_id" ref="microfinance_loan_management.view_microfinance_payment_form"/>
        <field name="arch" type="xml">
            <field name="journal_id" position="after">
                <field name="payment_origin" readonly="1"/>
            </field>
        </field>
    </record>
</odoo>
