<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_microfinance_savings" model="ir.ui.view">
        <field name="name">res.company.form.inherit.microfinance.savings</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="savings_product_code_locked" invisible="1"/>
                <field name="savings_product_code_prefix" readonly="savings_product_code_locked"/>
            </xpath>
        </field>
    </record>
</odoo>
