<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Financial Reports data records in the model account.financial.report-->
        <record id="account_financial_report_profitandloss0"
                model="account.financial.report">
            <field name="name">Profit and Loss</field>
            <field name="sign" eval="'-1'"/>
            <field name="type">sum</field>
        </record>
        <record id="account_financial_report_income0"
                model="account.financial.report">
            <field name="name">Income</field>
            <field name="sign" eval="'-1'"/>
            <field name="sequence">1</field>
            <field name="parent_id"
                   ref="account_financial_report_profitandloss0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">sum</field>
        </record>
        <record id="account_financial_report_operating_income0"
                model="account.financial.report">
            <field name="name">Operating Income</field>
            <field name="sequence">1</field>
            <field name="parent_id"
                   ref="financial_report_gross_profit"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">income</field>
        </record>
        <record id="account_financial_report_other_income0"
                model="account.financial.report">
            <field name="name">Other Income</field>
            <field name="sequence">10</field>
            <field name="parent_id"
                   ref="account_financial_report_income0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">income_other</field>
        </record>
        <record id="financial_report_gross_profit"
                model="account.financial.report">
            <field name="name">Gross Profit</field>
            <field name="parent_id"
                   ref="account_financial_report_income0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">sum</field>
            <field name="sequence">3</field>
        </record>
        <record id="financial_report_cost_of_revenue"
                model="account.financial.report">
            <field name="name">Cost of Revenue</field>
            <field name="sequence">10</field>
            <field name="parent_id"
                   ref="financial_report_gross_profit"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">expense_direct_cost</field>
        </record>
        <record id="account_financial_report_expense0"
                model="account.financial.report">
            <field name="name">Expense</field>
            <field name="sign" eval="'-1'"/>
            <field name="sequence">4</field>
            <field name="parent_id"
                   ref="account_financial_report_profitandloss0"/>
            <field name="display_detail">no_detail</field>
            <field name="type">sum</field>
        </record>
        <record id="account_financial_report_expense_regular0"
                model="account.financial.report">
            <field name="name">Expenses</field>
            <field name="sequence">1</field>
            <field name="parent_id"
                   ref="account_financial_report_expense0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">expense</field>
        </record>
        <record id="account_financial_report_expense_depreciation0"
                model="account.financial.report">
            <field name="name">Depreciation</field>
            <field name="sequence">2</field>
            <field name="parent_id"
                   ref="account_financial_report_expense0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">expense_depreciation</field>
        </record>
        <record id="account_financial_report_balancesheet0"
                model="account.financial.report">
            <field name="name">Balance Sheet</field>
            <field name="type">sum</field>
        </record>
        <record id="account_financial_report_assets0"
                model="account.financial.report">
            <field name="name">Assets</field>
            <field name="sequence">1</field>
            <field name="parent_id"
                   ref="account_financial_report_balancesheet0"/>
            <field name="display_detail">no_detail</field>
            <field name="type">sum</field>
        </record>
        <record id="account_financial_report_asset_fixed0"
                model="account.financial.report">
            <field name="name">Fixed Assets</field>
            <field name="sequence">1</field>
            <field name="parent_id"
                   ref="account_financial_report_assets0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">asset_fixed</field>
        </record>
        <record id="account_financial_report_asset_non_current0"
                model="account.financial.report">
            <field name="name">Non-current Assets</field>
            <field name="sequence">2</field>
            <field name="parent_id"
                   ref="account_financial_report_assets0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">asset_non_current</field>
        </record>
        <record id="account_financial_report_asset_current0"
                model="account.financial.report">
            <field name="name">Current Assets</field>
            <field name="sequence">10</field>
            <field name="parent_id"
                   ref="account_financial_report_assets0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">asset_current</field>
        </record>
        <record id="account_financial_report_asset_receivable0"
                model="account.financial.report">
            <field name="name">Receivable Accounts</field>
            <field name="sequence">20</field>
            <field name="parent_id"
                   ref="account_financial_report_assets0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">asset_receivable</field>
        </record>
        <record id="account_financial_report_asset_prepayments0"
                model="account.financial.report">
            <field name="name">Prepayments</field>
            <field name="sequence">30</field>
            <field name="parent_id"
                   ref="account_financial_report_assets0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">asset_prepayments</field>
        </record>
        <record id="account_financial_report_asset_cash0"
                model="account.financial.report">
            <field name="name">Bank and Cash</field>
            <field name="sequence">40</field>
            <field name="parent_id"
                   ref="account_financial_report_assets0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">asset_cash</field>
        </record>
        <record id="account_financial_report_liabilitysum0"
                model="account.financial.report">
            <field name="name">Liability</field>
            <field name="sequence">2</field>
            <field name="parent_id"
                   ref="account_financial_report_balancesheet0"/>
            <field name="display_detail">no_detail</field>
            <field name="type">sum</field>
        </record>
        <record id="account_financial_report_equity0"
                model="account.financial.report">
            <field name="name">Equity</field>
            <field name="sequence">1</field>
            <field name="parent_id"
                   ref="account_financial_report_liabilitysum0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">equity</field>
        </record>
        <record id="account_financial_report_equity_unaffected0"
                model="account.financial.report">
            <field name="name">Current Year Earnings</field>
            <field name="sequence">2</field>
            <field name="parent_id"
                   ref="account_financial_report_liabilitysum0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">equity_unaffected</field>
        </record>
        <record id="account_financial_report_profitloss_toreport0"
                model="account.financial.report">
            <field name="name">Profit (Loss) to report</field>
            <field name="sequence">3</field>
            <field name="parent_id"
                   ref="account_financial_report_liabilitysum0"/>
            <field name="display_detail">no_detail</field>
            <field name="type">account_report</field>
            <field name="account_report_id"
                   ref="account_financial_report_profitandloss0"/>
        </record>
        <record id="account_financial_report_liability0"
                model="account.financial.report">
            <field name="name">Liabilities</field>
            <field name="sequence">10</field>
            <field name="parent_id"
                   ref="account_financial_report_liabilitysum0"/>
            <field name="display_detail">no_detail</field>
            <field name="type">sum</field>
        </record>
        <record id="account_financial_report_liability_payable0"
                model="account.financial.report">
            <field name="name">Payable Accounts</field>
            <field name="sequence">1</field>
            <field name="parent_id"
                   ref="account_financial_report_liability0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">liability_payable</field>
        </record>
        <record id="account_financial_report_liability_current0"
                model="account.financial.report">
            <field name="name">Current Liabilities</field>
            <field name="sequence">10</field>
            <field name="parent_id"
                   ref="account_financial_report_liability0"/>
            <field name="display_detail">detail_with_hierarchy</field>
            <field name="type">account_type</field>
            <field name="account_type_ids">liability_current</field>
